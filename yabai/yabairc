yabai -m rule --add app="^Clock$"              manage=off
yabai -m rule --add app="^Find My$"            manage=off
yabai -m rule --add app="^Maps$"               manage=off
yabai -m rule --add app="^FaceTime$"           manage=off
yabai -m rule --add app="^Weather$"            manage=off
yabai -m rule --add app="^Finder$"             manage=off
yabai -m rule --add app="^Dictionary$"         manage=off
yabai -m rule --add app="^Headspace$"          manage=off
yabai -m rule --add app="^Raycast$"            manage=off
#yabai -m rule --add app="^Python$"             manage=off
yabai -m rule --add app="^Cisco Secure Client$"             manage=off
yabai -m rule --add app="^MoodistMac$"            manage=off
yabai -m rule --add app="^App Store$"            manage=off
yabai -m rule --add app="^Connection Matrix Workbench$"            manage=off

# Keep floating/unmanaged windows in normal macOS stacking order instead of
# pinning them above yabai-managed windows.
yabai -m rule --add app=".*" sub-layer=normal

# Keep Firefox Picture-in-Picture floating and above normal windows.
yabai -m rule --add label=firefox-pip \
  app="^Firefox$" title="^Picture-in-Picture$" \
  manage=off sub-layer=above

yabai -m signal --add event=window_resized app="sioyek" \
  action='/bin/bash /Users/maksim/.config/yabai/sioyek_resize.sh'

yabai -m rule --add app="sioyek" role="AXWindow" subrole="AXDialog" manage=on

yabai -m rule --add label=opacity-sioyek \
  app="^sioyek$" opacity=0.975

yabai -m rule --add label=opacity-wezterm \
  app="^WezTerm$" opacity=0.975

yabai -m rule --add label=opacity-codex \
  app="^Codex$" opacity=0.975

yabai -m rule --apply
