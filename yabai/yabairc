sudo -n /opt/homebrew/bin/yabai --load-sa

yabai -m signal --add event=dock_did_restart \
  action="sudo -n /opt/homebrew/bin/yabai --load-sa"

# bsp or float (default: bsp)
yabai -m config layout bsp

# Set all padding and gaps (default: 0)
yabai -m config top_padding    10
yabai -m config bottom_padding 10
yabai -m config left_padding   10
yabai -m config right_padding  10
yabai -m config window_gap     10

yabai -m config window_placement second_child

# global settings
yabai -m config mouse_follows_focus          on
#yabai -m config focus_follows_mouse          autoraise

# float system preferences
yabai -m rule --add app="^System Settings$"    manage=off
yabai -m rule --add app="^Activity Monitor$"   manage=off
yabai -m rule --add title="^About This Mac$"   manage=off
yabai -m rule --add app="^About This Mac$"     manage=off
yabai -m rule --add app="^Macs Fan Control$"   manage=off
yabai -m rule --add app="^Mail$"               manage=off
yabai -m rule --add app="^Calculator$"         manage=off
yabai -m rule --add app="^Karabiner-Elements$" manage=off
yabai -m rule --add app="^QuickTime Player$"   manage=off
yabai -m rule --add app="^Photo Booth$"        manage=off
yabai -m rule --add app="^UTM$"                manage=off
yabai -m rule --add app="^Books$"              manage=off
yabai -m rule --add app="^Mousecape$"          manage=off
yabai -m rule --add app="^Calendar$"           manage=off
yabai -m rule --add app="^Terminal$"           manage=off
yabai -m rule --add app="^MySFMLProject$"      manage=off
yabai -m rule --add app="^Preview$"            manage=off
yabai -m rule --add app="^Sitcky Notepad$"     manage=off
yabai -m rule --add app="^mpv$"                manage=off
yabai -m rule --add app="^Messages$"           manage=off
yabai -m rule --add app="^Notes$"              manage=off
