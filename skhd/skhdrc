# stop/start/restart yabai
ctrl + alt - q : yabai --stop-service
ctrl + alt - s : yabai --start-service
ctrl + alt - r : yabai --restart-service

# -- Window Focus or Swap --
alt - l : ~/.config/skhd/window_focus_or_swap.sh east
alt - h : ~/.config/skhd/window_focus_or_swap.sh west 
alt - j : ~/.config/skhd/window_focus_or_swap.sh south
alt - k : ~/.config/skhd/window_focus_or_swap.sh north

# Increase window width
shift + alt - l: ~/.config/skhd/window_resize.sh l
shift + alt - h: ~/.config/skhd/window_resize.sh h
shift + alt - j: ~/.config/skhd/window_resize.sh j
shift + alt - k: ~/.config/skhd/window_resize.sh k

# resize iterm to 
shift + alt - s : ~/.config/skhd/iterm_resize.sh 0.52
shift + alt - d : ~/.config/skhd/iterm_resize.sh 0.4
